@using PaniniTracker.Core.Models

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Page</th>
                <th>Code</th>
                <th>Σύνολο διπλών</th>
            </tr>
        </thead>

        <tbody>
            @if (Rows.Count == 0)
            {
                <tr>
                    <td colspan="3" class="empty">Δεν υπάρχουν διπλά.</td>
                </tr>
            }
            else
            {
                @foreach (var row in Rows)
                {
                    <tr>
                        <td>@row.Page</td>
                        <td>@row.Code</td>
                        <td>@row.Count</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public List<DuplicateStickerRow> Rows { get; set; } = new();
}
